# Full URL to the Disco daemon's SSE endpoint.
DISCO_EVENTS_URL=https://your-disco-host/api/disco/events

# A DEDICATED Disco API key (create a separate invite for this; don't reuse yours).
# Used as HTTP Basic username with an empty password.
DISCO_API_KEY=your_dedicated_disco_api_key

# Slack incoming webhook for the channel you want to post to.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# The daemon streams events for ALL projects on the server — restrict to yours.
# Comma-separated Disco project names; leave empty to notify for every project.
DISCO_PROJECT_FILTER=my-app

# --- optional tuning -------------------------------------------------------
# TERMINAL_STATES=COMPLETE,COMPLETED,FAILED
# RECONNECT_DELAY=5
# STATE_FILE=/data/last_event_id
# LOG_LEVEL=INFO
# Set to 1 to log full raw event payloads (use on first run to confirm schema).
# DEBUG_EVENTS=1
